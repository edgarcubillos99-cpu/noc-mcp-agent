# ==========================================
# CONFIGURACIÓN DEL AGENTE MCP NOC
# ==========================================
# Puerto TCP para el servidor HTTP/SSE
HTTP_PORT=8080
# Entorno de ejecución (development, production)
APP_ENV=production

# Nivel de logging estructurado (debug, info, warn, error)
LOG_LEVEL=info

# ==========================================
# LÍMITES Y SEGURIDAD (Protección DoS)
# ==========================================
# Límite de goroutines concurrentes para herramientas de red
MAX_PING_WORKERS=50
MAX_NMAP_CONCURRENCY=5
